{
  "name": "crystal",
  "version": "0.0.0",
  "private": true,
  "description": "Crystal desktop application bootstrap.",
  "type": "module",
  "main": "dist/main/main.cjs",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run build && electron dist/main/main.cjs",
    "install:electron-runtime": "node scripts/install-electron-runtime.mjs",
    "postinstall": "node scripts/install-electron-runtime.mjs",
    "build": "node scripts/build.mjs",
    "build:main": "node scripts/build-ts.mjs main",
    "build:preload": "node scripts/build-ts.mjs preload",
    "build:renderer": "npm run build:html && npm run build:scss && node scripts/build-ts.mjs renderer",
    "build:html": "node scripts/build-html.mjs",
    "build:scss": "node scripts/build-scss.mjs",
    "build:ts": "node scripts/build-ts.mjs",
    "typecheck": "tsc --noEmit",
    "sync:project-metadata": "node scripts/sync-project-metadata.mjs --write",
    "validate:project-metadata": "node scripts/sync-project-metadata.mjs --check",
    "validate:project-metadata:json": "node scripts/sync-project-metadata.mjs --check --json",
    "validate:change-policy": "node scripts/validate-change-policy.mjs",
    "validate:markdown-integrity": "node scripts/validate-markdown-integrity.mjs",
    "validate:structure": "node scripts/validate-structure.mjs",
    "validate:project-graph": "node scripts/validate-project-graph.mjs",
    "validate:project-watch": "node scripts/validate-project-watch.mjs",
    "validate:preview": "node scripts/validate-preview.mjs",
    "validate:dom-snapshot": "node scripts/validate-dom-snapshot.mjs",
    "validate:preview-selection": "node scripts/validate-preview-selection.mjs",
    "validate:preview-inspector": "node scripts/validate-preview-inspector.mjs",
    "validate:design-canvas": "node scripts/validate-design-canvas.mjs",
    "validate:visual-selection-overlay": "node scripts/validate-visual-selection-overlay.mjs",
    "validate:html-element-library": "node scripts/validate-html-element-library.mjs",
    "validate:source-patch-preview": "node scripts/validate-source-patch-preview.mjs",
    "validate:history-foundation": "node scripts/validate-history-foundation.mjs",
    "validate:design-editing-preflight": "node scripts/validate-design-editing-preflight.mjs",
    "validate:inspector-editing-foundation": "node scripts/validate-inspector-editing-foundation.mjs",
    "validate:editable-inspector-surface": "node scripts/validate-editable-inspector-surface.mjs",
    "validate:style-engine-foundation": "node scripts/validate-style-engine-foundation.mjs",
    "validate:authored-style-matching": "node scripts/validate-authored-style-matching.mjs",
    "validate:css-sass-inspector-surface": "node scripts/validate-css-sass-inspector-surface.mjs",
    "validate:guided-docs": "node scripts/validate-guided-docs.mjs",
    "validate:architecture-docs": "node scripts/validate-architecture-docs.mjs",
    "validate:ui-flow": "node scripts/validate-ui-flow.mjs",
    "validate:validation-system": "node scripts/validate-validation-system.mjs",
    "validate:local": "node scripts/validate-local.mjs",
    "validate:local:quick": "node scripts/validate-local-quick.mjs",
    "validate:local:quick:json": "node scripts/validate-local-quick.mjs --json-summary",
    "validate:local:quick:verbose": "node scripts/validate-local-quick.mjs --verbose",
    "validate:local:quick:fail-fast": "node scripts/validate-local-quick.mjs --fail-fast",
    "validate:local:watch": "node scripts/validate-local-watch.mjs",
    "doctor:electron": "node scripts/doctor-electron.mjs",
    "test:tooling-hardening": "node --test tests/tooling/*.test.mjs",
    "validate:local:quick:core": "npm run validate:structure && npm run validate:source-tree-boundaries && npm run validate:project-graph && npm run validate:project-watch && npm run validate:history-foundation && npm run validate:design-editing-preflight && npm run validate:inspector-editing-foundation && npm run validate:style-engine-foundation && npm run validate:authored-style-matching",
    "validate:local:quick:preview": "npm run validate:preview && npm run validate:dom-snapshot && npm run validate:preview-selection && npm run validate:preview-inspector",
    "validate:local:quick:ui": "npm run validate:design-canvas && npm run validate:visual-selection-overlay && npm run validate:html-element-library && npm run validate:source-patch-preview && npm run validate:editable-inspector-surface && npm run validate:css-sass-inspector-surface && npm run validate:ui-flow",
    "validate:source-tree-boundaries": "node scripts/validate-source-tree-boundaries.mjs",
    "validate:source-freshness-foundation": "node scripts/validate-source-freshness-foundation.mjs"
  },
  "devDependencies": {
    "@types/node": "^24.13.3",
    "electron": "^43.1.0",
    "esbuild": "^0.28.1",
    "sass": "^1.101.0",
    "typescript": "^7.0.2"
  },
  "engines": {
    "node": ">=24.18.0 <25",
    "npm": ">=10.0.0"
  }
}
