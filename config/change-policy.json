{
  "schemaVersion": 1,
  "policies": [
    {
      "name": "documentation-only",
      "branchPrefix": "docs/",
      "allow": [
        "docs/**",
        "README.md"
      ],
      "denyExtensions": [
        ".png",
        ".jpg",
        ".jpeg",
        ".svg"
      ]
    },
    {
      "name": "tooling",
      "branchPrefix": "tooling/",
      "priority": 10,
      "allow": [
        ".github/**",
        ".nvmrc",
        "README.md",
        "config/**",
        "docs/**",
        "package.json",
        "package-lock.json",
        "scripts/**",
        "tests/**"
      ],
      "denyExtensions": []
    },
    {
      "name": "obsolete-root-scaffold-cleanup",
      "branchPrefix": "tooling/remove-obsolete-root-scaffolds",
      "priority": 100,
      "allow": [
        "config/change-policy.json",
        "scripts/validate-change-policy.mjs",
        "tests/tooling/tooling-hardening.test.mjs",
        "packages/engine/**",
        "packages/build-tools/**"
      ],
      "denyExtensions": []
    }
  ]
}
